@base_url = http://127.0.0.1:8000


###TESTE
GET {{base_url}}/ HTTP/1.1
Content-Type: application/json

##-----------------------------------AVALIACAO--------------------------------##

###criar 
POST {{base_url}}/avaliacao HTTP/1.1
Content-Type: application/json

{
    "nota_passageiro": 4,
    "nota_motorista": 5,
    "datahora_limite": "2024-05-12 12:43:54"
}
###listar
GET {{base_url}}/avaliacao/avaliações HTTP/1.1
Accept: application/json

###deletar
DELETE {{base_url}}/avaliacao/delete/3 HTTP/1.1
Accept: application/json

###atualizar
PUT {{base_url}}/avaliacao/update/6 HTTP/1.1
Content-Type: application/json

{
    "nota_passageiro": 4,
    "nota_motorista": 5,
    "datahora_limite": "2024-05-12 12:43:54"
}

